
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String

  profile Profile?
  posts Posts[]
  likes Likes []
  comments Comments []
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")
  sentMessages Msgs[] @relation("SentMessages")
  receivedMessages Msgs[] @relation("ReceivedMessages")

}

model Profile {
    id Int @id @default(autoincrement())
    user Int @unique
    pfp String? @default("default-png")
    name String
    username String
    email String

    accountStatus String @default("public")
    blockedAccounts Blocked []

    userProfile User @relation(fields: [user], references: [id])

}

model Posts {
  id Int @id @default(autoincrement())
  madeBy Int 
  msg String
  createdAt DateTime @default(now())
  likes Likes[]
  comments Comments[]

  postedBy User @relation(fields: [madeBy], references: [id])

}

model Likes {
    id Int @id @default(autoincrement())
    postID Int
    idOfLiker Int
    likedAt DateTime @default(now())

    post Posts @relation(fields: [postID], references: [id])
    user User @relation(fields: [idOfLiker], references: [id])

}

model Comments {
    id Int @id @default(autoincrement())
    postID Int
    commenterID Int
    comment String
    createdAt DateTime @default(now())
    
    post Posts @relation(fields: [postID], references: [id])
    user User @relation(fields: [commenterID], references: [id])
}

model Follow {
  id Int @id @default(autoincrement())

  followerId Int
  followingId Int

  follower   User @relation("UserFollowing", fields: [followerId], references: [id])
  following  User @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Msgs {
  id Int    @id @default(autoincrement())
  senderId  Int
  receiverId Int
  message   String
  image String?
  createdAt DateTime @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User @relation("ReceivedMessages", fields: [receiverId], references: [id])

}


model Blocked {
  id Int @id @default(autoincrement())
  blockerId   Int
  blockedId   Int

  profile Profile @relation(fields: [blockerId], references: [user])

  @@unique([blockerId, blockedId])

}

// on delete of comments or likes cascade