
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String

  profile Profile?
  posts Posts[]
  likes Likes []
  reposts Reposts[]
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")
  sentMessages Msgs[] @relation("SentMessages")
  receivedMessages Msgs[] @relation("ReceivedMessages")

}

model Profile {
    id Int @id @default(autoincrement())
    user Int @unique
    pfp String @default("default-png.jpng")
    name String
    username String
    email String

    blockedAccounts Blocked []

    userProfile User @relation(fields: [user], references: [id])

}

model Posts {
  id Int @id @default(autoincrement())
  madeBy Int
  msg String
  img String?
  createdAt DateTime @default(now())
  commentOnPostID Int?

  likes Likes[]
  reposts Reposts[]
  commentReplies Posts[] @relation("PostComments")

  postedBy User @relation(fields: [madeBy], references: [id])
  commentOnPost Posts? @relation("PostComments", fields: [commentOnPostID], references: [id])

}

model Likes {
    id Int @id @default(autoincrement())
    postID Int
    idOfLiker Int
    likedAt DateTime @default(now())

    post Posts @relation(fields: [postID], references: [id])
    user User @relation(fields: [idOfLiker], references: [id])

}


model Reposts {
    id Int @id @default(autoincrement())
    postID Int
    repostedBy Int
    repostedAt DateTime @default(now())

    post Posts @relation(fields: [postID], references: [id])
    user User @relation(fields: [repostedBy], references: [id])

    @@unique([postID, repostedBy])
}

model Msgs {
  id Int    @id @default(autoincrement())
  senderID  Int
  receiverID Int
  message   String
  image String?
  createdAt DateTime @default(now())
  deletedBySender Boolean @default(false)
  deletedByReceiver Boolean @default(false)

  sender    User @relation("SentMessages", fields: [senderID], references: [id])
  receiver  User @relation("ReceivedMessages", fields: [receiverID], references: [id])

}

model Follow {
  id Int @id @default(autoincrement())

  followerID Int
  followingID Int

  follower   User @relation("UserFollowing", fields: [followerID], references: [id])
  following  User @relation("UserFollowers", fields: [followingID], references: [id])

  @@unique([followerID, followingID])
}

model Blocked {
  id Int @id @default(autoincrement())
  blockerID   Int
  blockedID   Int

  profile Profile @relation(fields: [blockerID], references: [user])

  @@unique([blockerID, blockedID])

}

// on delete of comments or likes cascade