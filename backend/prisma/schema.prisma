
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String

  profile Profile[]
  posts Posts[]
  likes Likes []
  comments Comments []
  following Following[]
  followers Followers[]

}

model Profile {
    id Int @id @default(autoincrement())
    user Int 
    pfp String @default("default-png")
    name String
    username String
    email String
    
    accountStatus String @default("public")
    blockedAccounts Blocked []

    userProfile User @relation(fields: [user], references: [id])

}

model Posts {
  id Int @id @default(autoincrement())
  madeBy Int 
  createdAt DateTime @default(now())
  likes Int
  comments 

}

model Likes {
    id Int @id @default(autoincrement())
    userLikes Int 

}

model Comments {
      id Int @id @default(autoincrement())
    userComments Int 

}

model Msgs {

}

model Following {
      id Int @id @default(autoincrement())
    userFollowing Int 

}

model Followers {
      id Int @id @default(autoincrement())
    userFollowers Int 

}

model Blocked {

}